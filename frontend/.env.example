DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yerbamate"

# Admin credentials (required for seeding admin user; run: npx prisma db seed)
ADMIN_EMAIL="alise@yerbatea.lv"
ADMIN_PASSWORD="your_strong_admin_password_here"

# Cron job authentication (required for scheduled tasks like abandoned cart emails)
CRON_SECRET="generate_a_random_secret_here"
# Abandoned cart defaults (can also be edited in /admin/abandoned-carts)
ABANDONED_CART_DEFAULT_TIMEOUT_MINUTES="1440"
ABANDONED_CART_DEFAULT_COOLDOWN_HOURS="24"
ABANDONED_CART_DEFAULT_FIRST_DELAY_HOURS="24"
ABANDONED_CART_DEFAULT_SECOND_DELAY_HOURS="72"
ABANDONED_CART_DEFAULT_THIRD_DELAY_HOURS="168"

# Stripe (required to accept payments)
# Use test keys in development and live keys in production.
STRIPE_SECRET_KEY="sk_test_replace_me"
# Webhook signing secret for /api/stripe/webhook (required in production for checkout).
# In Stripe Dashboard: Developers → Webhooks → your endpoint → "Signing secret" (starts with whsec_).
# Must match the same mode as STRIPE_SECRET_KEY (test vs live). Trim spaces; no quotes in production env if possible.
# During secret rotation you can set two comma- or newline-separated secrets; both are accepted until you remove the old one.
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
#
# If Stripe shows "Invalid signature" but the URL is reachable: your reverse proxy must forward the raw body
# unchanged and the header "Stripe-Signature". Example nginx: proxy_request_buffering off; for this location.

# Maksekeskus / Makecommerce (optional second payment option: bank links, cards)
# Get Shop ID and Secret from https://merchant.maksekeskus.ee (live) or https://merchant.test.maksekeskus.ee (test)
# MAKSEKESKUS_SHOP_ID="your_shop_id"
# MAKSEKESKUS_SECRET_KEY="your_secret_key"
# Optional: override API base (default: test in dev, live in production)
# MAKSEKESKUS_BASE_URL="https://api.test.maksekeskus.ee"

# Public site origin (used for emails and Stripe redirect URLs)
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
# Canonical auth origin used for OAuth callback URLs and auth redirects
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — in Google Cloud Console add Authorized redirect URI exactly:
#   {NEXT_PUBLIC_APP_ORIGIN or OAUTH_PUBLIC_ORIGIN}/api/auth/callback/google
# If "Access blocked" / redirect_uri_mismatch, set the same canonical URL here and in Console:
# OAUTH_PUBLIC_ORIGIN="https://www.yourdomain.com"
GOOGLE_CLIENT_ID="google_client_id_here"
GOOGLE_CLIENT_SECRET="google_client_secret_here"

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Email via Resend (order confirmation, abandoned cart, newsletter contact sync)
RESEND_API_KEY="re_replace_me"
RESEND_FROM="YerbaTea <orders@yerbatea.lv>"
# Optional: also add newsletter signups to a Resend Segment
# RESEND_SEGMENT_ID="replace_me"

# DPD Shipping Integration (required for DPD labels)
# Get credentials from https://eserviss.dpd.lv
DPD_USERNAME="your_dpd_email"
DPD_PASSWORD="your_dpd_password"

# Instagram (optional) — for homepage 3x3 grid below reviews.
# Option A (recommended): Instagram Graph API (Business/Creator).
# - Provide a long-lived User or Page access token from Meta (Graph API), NOT the App Secret.
# - Token must match graph.facebook.com (usually starts with EAAG... for a long-lived user token).
# - No wrapping quotes in production env if your host injects them literally.
# - If logs show OAuth 190 "could not be decrypted", the string is wrong/truncated/wrong app.
# - If your Meta app requires server calls to include app secret proof, set:
# META_APP_SECRET="your_app_secret_from_meta_dashboard"
# INSTAGRAM_GRAPH_API_ACCESS_TOKEN=EAAG...
# INSTAGRAM_IG_USER_ID=1784140...
#
# Option B: Instagram Basic Display.
# - Create an access token with user_media scope.
# - Used as fallback if Graph API vars are not set.
# INSTAGRAM_ACCESS_TOKEN="igq...replace_me"

# Encryption key for PII (generate with: openssl rand -base64 32)
# Required for GDPR compliance - encrypts sensitive customer data
ENCRYPTION_KEY="generate_with_openssl_rand_base64_32"
