// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  REQUIRES_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  CANCELLED
  REFUNDED
}

enum ShippingMethodType {
  FLAT
  WEIGHT_BASED
  PRICE_BASED
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum PaymentMethod {
  STRIPE
  WIRE_TRANSFER
  MAKSEKESKUS
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum AdminRole {
  OWNER
  ADMIN
  MANAGER
  SUPPORT
}

model DiscountCode {
  id            String       @id @default(cuid())
  code          String       @unique
  type          DiscountType
  value         Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  active        Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([code])
  @@index([active])
}

model BundleOffer {
  id              String   @id @default(cuid())
  name            String
  description     String?
  minQuantity     Int
  discountPercent Decimal  @db.Decimal(5, 2)
  productId       String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([productId])
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  name               String?
  image              String?
  isAdmin            Boolean   @default(false)
  /// RBAC: when set, works with isAdmin for admin panel access (see hasAdminAccess).
  adminRole          AdminRole?
  resetToken         String?   @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts               Account[]
  carts                  Cart[]
  orders                 Order[]
  reviews                Review[]
  sessions               Session[]
  wishlistItems          WishlistItem[]
  adminAuditLogs         AdminAuditLog[]      @relation("AdminAuditActor")
  orderAdminNotes        OrderAdminNote[]
  inventoryAdjustments   InventoryAdjustment[]
  customerProfile        CustomerProfile?

  @@index([email])
  @@index([resetToken])
  @@index([adminRole])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([sortOrder])
}

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String?
  descriptionEn String?       @db.Text
  descriptionLv String?       @db.Text
  price         Decimal        @db.Decimal(10, 2)
  /// Optional strike-through / “was” price for storefront.
  compareAtPrice Decimal?      @db.Decimal(10, 2)
  currency      String         @default("EUR")
  barcode       String?        @unique
  brand         String?
  origin        String?
  weight        String?
  /// Shipping weight per unit (kg), used for EU postal quotes. Optional; falls back to parsing `weight` text.
  shippingWeightKg Decimal? @db.Decimal(10, 3)
  /// "instock" = use quantity, show "In stock" or "Get in 5-7 days"; "warehouse" = show "Get in 5-7 days"
  stockLocation String?        @default("instock")
  active        Boolean        @default(true)
  /// Hidden from default admin list; excluded from storefront when true
  archived      Boolean        @default(false)
  /// Draft products never appear on the storefront (even if active).
  isDraft       Boolean        @default(false)
  categoryId    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images       ProductImage[]
  variants     Variant[]
  orderItems   OrderItem[]
  cartItems    CartItem[]
  bundleOffers BundleOffer[]
  collections   ProductInCollection[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([slug])
  @@index([active])
  @@index([archived])
  @@index([isDraft])
  @@index([barcode])
  @@index([categoryId])
  @@index([brand])
  @@index([origin])
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductInCollection[]

  @@index([slug])
}

model ProductInCollection {
  id           String     @id @default(cuid())
  collectionId String
  productId    String
  position     Int        @default(0)
  createdAt    DateTime   @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  altText   String?
  position  Int     @default(0)
  focalX    Float   @default(0.5)
  focalY    Float   @default(0.5)
  zoom      Float   @default(1)

  @@index([productId])
}

/// Optional variant model for sizes/colors, etc.
model Variant {
  id            String    @id @default(cuid())
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String
  sku           String    @unique
  attributes    Json?
  priceOverride Decimal?  @db.Decimal(10, 2)
  active        Boolean   @default(true)

  inventoryItems InventoryItem[]
  orderItems     OrderItem[]
  cartItems      CartItem[]

  @@index([productId])
  @@index([active])
}

model InventoryItem {
  id        String   @id @default(cuid())
  sku       String
  variant   Variant? @relation(fields: [variantId], references: [id])
  variantId String?
  quantity  Int      @default(0)
  location  String?  // e.g. warehouse name or code
  updatedAt DateTime @updatedAt

  adjustments InventoryAdjustment[]

  @@index([sku])
  @@index([variantId])
}

model Cart {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  sessionId String?  @unique
  email     String?  // optional: for abandoned-cart emails (e.g. from cart page)
  abandonedCartEmailSentAt DateTime?  // when we sent abandoned-cart reminder (avoid duplicate)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model Policy {
  id        String   @id @default(cuid())
  slug      String
  locale    String
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
  @@index([slug])
}

model CartItem {
  id        String   @id @default(cuid())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  variantId String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2) // snapshot of price at time of adding

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  user                  User?         @relation(fields: [userId], references: [id])
  userId                String?
  email                 String
  sessionId             String?       // cart session at checkout, for abandoned-cart attribution
  status                OrderStatus   @default(PENDING)
  customerType          CustomerType  @default(INDIVIDUAL)
  paymentMethod         PaymentMethod @default(STRIPE)
  companyName           String?
  companyAddress        String?
  vatNumber             String?
  phone                 String?
  subtotal              Decimal       @db.Decimal(10, 2)
  discountCode          String?
  discountAmount        Decimal?      @db.Decimal(10, 2)
  shippingCost          Decimal       @db.Decimal(10, 2)
  tax                   Decimal       @db.Decimal(10, 2)
  total                 Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD")
  shippingAddress       Json          // full shipping address snapshot
  billingAddress        Json?         // optional billing address snapshot
  stripePaymentIntentId     String?
  maksekeskusTransactionId  String?
  confirmationEmailSentAt   DateTime?   // when order confirmation email was last sent
  reviewRequestEmailSentAt DateTime? // when "leave a review" email was sent (4 days after order)
  dpdShipmentId         String?       // DPD shipment ID
  dpdTrackingNumber     String?       // DPD tracking number
  dpdLabelPdf           String?       @db.Text // Base64 encoded PDF label
  dpdLabelCreatedAt     DateTime?     // when DPD label was generated
  dpdSentAt             DateTime?     // when DPD first accepted the parcel / left warehouse
  dpdDeliveredAt        DateTime?     // when DPD marked the parcel as delivered
  dpdLastStatus         String?       // last raw status text/code from DPD
  dpdLastStatusAt       DateTime?     // when last DPD status was recorded
  archived              Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  items           OrderItem[]
  reviews         Review[]
  invoice         Invoice?
  orderAdminNotes OrderAdminNote[]

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([sessionId])
  @@index([archived])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model OrderAdminNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([authorId])
}

/// Internal CRM row: one per normalized customer email (guest or registered).
model CustomerProfile {
  id              String   @id @default(cuid())
  email           String   @unique
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  internalNotes   String?  @db.Text
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
}

model InventoryAdjustment {
  id              String         @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  delta           Int
  quantityAfter   Int
  reason          String?
  actorId         String
  actor           User           @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([inventoryItemId])
  @@index([actorId])
  @@index([createdAt])
}

model InvoiceCounter {
  id         String   @id @default("default")
  nextNumber Int      @default(1)
  updatedAt  DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String   @unique
  customerEmail String
  customerName  String?
  phone         String?
  pdfBase64     String   @db.Text
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([customerEmail])
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId   String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  authorEmail String
  authorName  String?
  rating    Int      // 1-5
  title     String?  @db.VarChar(200)
  body      String?  @db.Text
  status    String   @default("PENDING") // PENDING | APPROVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String
  sessionId String?
  userId    String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([createdAt])
  @@index([sessionId])
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  variantId String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String
  countries Json     // e.g. array of ISO country codes

  methods ShippingMethod[]
}

model ShippingMethod {
  id            String             @id @default(cuid())
  zone          ShippingZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  zoneId        String
  name          String
  type          ShippingMethodType
  rateConfig    Json               // configuration for flat/weight/price tiers
  estimatedDays Int?
  active        Boolean            @default(true)

  @@index([zoneId])
  @@index([active])
}

/// Single-row settings: free shipping threshold and DPD parcel price per country.
model ShippingSettings {
  id                       String   @id @default("default")
  freeShippingThreshold    Decimal? @db.Decimal(10, 2)
  freeShippingCurrency     String?  @default("EUR")
  dpdPriceByCountry        Json?    // e.g. { "LV": 4.99, "EE": 5.99, "LT": 4.99 }
  /// Optional override for EU registered parcel matrix { "DE": { "baseUnder1kg": 17.89, "additionalPerKg": 2.37 }, ... }
  euRegisteredParcelRates  Json?
  updatedAt                DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  sessionToken String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model EmailCampaign {
  id          String   @id @default(cuid())
  name        String
  subject     String
  htmlContent String   @db.Text
  sentAt      DateTime?
  sentCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sentAt])
}

model SiteSettings {
  id                           String   @id @default("default")
  popupEnabled                 Boolean  @default(true)
  popupDelaySeconds            Int      @default(10)
  popupTitle                   String   @default("Join YerbaTea Community")
  popupDescription             String   @default("Subscribe to our newsletter and get an exclusive discount on your first order!")
  popupDiscountCode            String?
  popupDiscountPercent         Int      @default(10)
  homeNewArrivalsCollectionId  String?
  homeTopSellingCollectionId   String?
  homePromoProductIds          String[]  @default([])
  updatedAt                    DateTime @updatedAt
}

/// Admin-editable UI translation overrides. Key + locale unique; defaults from locales/*.json.
model Translation {
  id     String @id @default(cuid())
  key    String
  locale String
  value  String @db.Text

  @@unique([key, locale])
  @@index([locale])
}
