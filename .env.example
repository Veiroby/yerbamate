DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yerbamate"

# Stripe (required to accept payments)
# Use test keys in development and live keys in production.
STRIPE_SECRET_KEY="sk_test_replace_me"
# Webhook signing secret for /api/stripe/webhook (recommended; required in production)
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Public site origin (used for emails and Stripe redirect URLs)
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
# Canonical auth origin used for OAuth callback URLs and auth redirects
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="google_client_id_here"
GOOGLE_CLIENT_SECRET="google_client_secret_here"

# Email via Resend (order confirmation, abandoned cart, newsletter contact sync)
RESEND_API_KEY="re_replace_me"
RESEND_FROM="YerbaTea <orders@yerbatea.lv>"
# Optional: also add newsletter signups to a Resend Segment
# RESEND_SEGMENT_ID="replace_me"

# DPD Shipping Integration (required for DPD labels)
# Get credentials from https://eserviss.dpd.lv
DPD_USERNAME="your_dpd_email"
DPD_PASSWORD="your_dpd_password"
